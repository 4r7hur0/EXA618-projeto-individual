DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=smartphones
DB_USERNAME=postgres
DB_PASSWORD=
LOG_LEVEL=DEBUG

# Crawlers em paralelo (3 threads, cada uma com loop asyncio próprio).
# CRAWLER_PARALLEL=1

# Quantas ofertas distintas buscar na Amazon e no Mercado Livre por consulta (1–8; padrão 4).
# OFERTAS_POR_BUSCA=4

# Recarregar app ao editar arquivos (uvicorn --reload). No Windows pode ser instável.
# WEB_RELOAD=1

# Opcional: URL completa (sobrescreve DB_* acima)
# DATABASE_URL=postgresql+psycopg2://postgres@localhost:5432/smartphones

# Reutilizar busca recente no banco (mesmo termo normalizado) sem rodar os crawlers.
# CACHE_BUSCA_HORAS=72

# Intervalo em minutos para o job atualizar preços das ofertas salvas (0 = desliga).
# PRECOS_JOB_INTERVAL_MINUTES=360

# Timeout (ms) para page.goto no Mais Celular (padrão 90000; mín. 25000, máx. 180000).
# MAISCELULAR_NAV_TIMEOUT_MS=90000
